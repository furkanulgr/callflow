# ─────────────────────────────────────────────────────────
# LUERA CallFlow — Environment Variables
# Kopyala: cp .env.example .env.local  (asla commit etme)
# ─────────────────────────────────────────────────────────

# ── ElevenLabs — Ana Workspace (Kemal, Elif, Onur agentları) ──
VITE_ELEVENLABS_API_KEY=sk_...

# ── ElevenLabs — LUNA Workspace (ayrı hesap) ──
VITE_LUNA_API_KEY=sk_...
VITE_LUNA_AGENT_ID=agent_...

# ── ElevenLabs — Varsayılan Agent (LiveTest, Demo) ──
VITE_ELEVENLABS_AGENT_ID=agent_...

# ── Twilio — ElevenLabs panelinden import edilen numara ID'si ──
VITE_ELEVENLABS_PHONE_NUMBER_ID=phnum_...

# ── Quick Call — Test için aranacak numara (+90 ile başlayan) ──
VITE_QUICK_CALL_TEST_NUMBER=+90...

# ── Supabase (Faz 1'de eklenecek) ──
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
