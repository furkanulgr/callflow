# ─── Twilio ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+901234567890

# WhatsApp Business numarası (opsiyonel — tanımlı değilse /api/whatsapp/* çalışmaz)
# Twilio Sandbox: +14155238886  |  Prodüksiyon: kendi WhatsApp Business numaranız
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── ElevenLabs ───────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs webhook HMAC secret (ElevenLabs dashboard'dan alınır)
# Format: wsec_xxxxxxxxxxxxxxxx
ELEVENLABS_WEBHOOK_SECRET=wsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ───────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Production'da Railway/Render'ın verdiği public URL
SERVER_URL=https://your-callflow-bridge.up.railway.app

# ─── Hata Takibi ──────────────────────────────────────
# Sentry DSN (opsiyonel — sentry.io'dan alınır)
SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# ─── CORS ─────────────────────────────────────────────
# Frontend domain(ları), virgülle ayrılmış
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# ─── n8n Entegrasyonu (opsiyonel) ─────────────────────
# n8n webhook proxy için — ayarlı değilse /api/n8n/* 503 döner
N8N_BASE_URL=https://your-n8n.example.com
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/callflow
